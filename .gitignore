# Métadonnées Windows/WSL
*Zone.Identifier

# Captures d'écran de travail
*.png
*.jpg

# Données d'astro (jamais versionnées)
*.fits
*.fit
*.FITS
*.FIT
*.xisf

# Divers
__pycache__/
*.pyc

# Artefacts de distribution (générés)
dist/


# Sorties générées par le runner de tests
tests/build/

# Signature de code PixInsight : la clé ne doit JAMAIS entrer dans ce
# repo public. *.xsgn couvre surtout une signature manuelle du script à
# la racine (Script > Development > CodeSign) — celle du packaging vit
# sous dist/, déjà ignoré.
*.xssk
*.xsgn
